{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"]
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "next.config.mjs"],
  "exclude": ["node_modules"]
}
