# App
# Local:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Vercel production (use your real deployment URL):
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
NEXT_PUBLIC_APP_NAME=Nexus HRMS
# Demo auth (local only). Do NOT set on Vercel for real employees.
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false

# Neon PostgreSQL — get connection string from https://console.neon.tech
# Use the same URL for both, or use the "-pooler" host for DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# OpenRouter (https://openrouter.ai) — separate keys per feature
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_RESUME_API_KEY=sk-or-v1-your-resume-key
OPENROUTER_CHAT_API_KEY=sk-or-v1-your-chat-interview-key
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_RESUME_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Legacy fallback (optional — used if OpenRouter keys are not set)
OPENAI_API_KEY=

# Supabase (optional — auth & file storage only; not used for database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local demo quick-login only (NEXT_PUBLIC_DEMO_MODE=true). Not used in production onboarding.
DEMO_MODE_PASSWORD=demo-local-only

# Admin password recovery (OTP sent here — no other user approval required)
ADMIN_RECOVERY_EMAIL=arjavjainaj310@gmail.com
OTP_SECRET=generate-a-long-random-string
# Resend (https://resend.com) — required in production to email OTPs
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=Nexus HRMS <noreply@yourdomain.com>
