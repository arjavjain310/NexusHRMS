# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Nexus HRMS
DEMO_MODE=true

# Neon PostgreSQL — get connection string from https://console.neon.tech
# Use the same URL for both, or use the "-pooler" host for DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# OpenAI (optional — enables full AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Supabase (optional — auth & file storage only; not used for database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
